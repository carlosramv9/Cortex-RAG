# ---------------------------------------------------------------------------
# knowledge-service — environment configuration
# Copy to .env and adjust. All settings load through app.config.settings.Settings
# ---------------------------------------------------------------------------

# --- App ---
APP_NAME=knowledge-service
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_LOG_JSON=false

# --- CORS (comma-separated origins) ---
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=knowledge
DB_PASSWORD=knowledge
DB_NAME=knowledge
DB_ECHO=false

# --- Qdrant ---
VECTOR_HOST=qdrant
VECTOR_PORT=6333
VECTOR_COLLECTION=knowledge_chunks
# Must match EMBEDDING_DIMENSION below (fixed at collection creation time).
VECTOR_VECTOR_SIZE=1024

# --- Gemini (chat/answer pipeline — https://aistudio.google.com/apikey) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- Chat / RAG behavior ---
CHAT_HISTORY_WINDOW=20

# --- Embeddings (local, in-process via fastembed — no server, no API key) ---
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIMENSION=1024

# --- Storage ---
STORAGE_LOCAL_PATH=./storage
STORAGE_PAGE_IMAGE_FORMAT=webp

# --- Upload validation policy (lists accept comma-separated or JSON) ---
UPLOAD_MAX_SIZE_MB=200
UPLOAD_ALLOWED_EXTENSIONS=pdf
UPLOAD_ALLOWED_MIME_TYPES=application/pdf

# --- Async processing pipeline ---
PROCESSING_MAX_RETRIES=3
PROCESSING_DEFAULT_PRIORITY=0

# --- RabbitMQ (the actual processing-job queue — push-based, no polling) ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=processing_jobs
RABBITMQ_PREFETCH_COUNT=10
