# ---------------------------------------------------------------------------
# knowledge-service — environment configuration
# Copy to .env and adjust. All settings load through app.config.settings.Settings
# ---------------------------------------------------------------------------

# --- App ---
APP_NAME=knowledge-service
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
APP_LOG_JSON=false

# --- CORS (comma-separated origins) ---
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# --- PostgreSQL ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=knowledge
DB_PASSWORD=knowledge
DB_NAME=knowledge
DB_ECHO=false

# --- Qdrant (not wired yet, reserved) ---
VECTOR_HOST=qdrant
VECTOR_PORT=6333
VECTOR_COLLECTION=knowledge_chunks

# --- LLM / Embeddings (Ollama, external — not wired yet, reserved) ---
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.1
EMBEDDING_MODEL=bge-m3

# --- Storage ---
STORAGE_LOCAL_PATH=./storage
STORAGE_PAGE_IMAGE_FORMAT=webp

# --- Upload validation policy (lists accept comma-separated or JSON) ---
UPLOAD_MAX_SIZE_MB=50
UPLOAD_ALLOWED_EXTENSIONS=pdf
UPLOAD_ALLOWED_MIME_TYPES=application/pdf

# --- Async processing pipeline ---
PROCESSING_MAX_RETRIES=3
PROCESSING_DEFAULT_PRIORITY=0
PROCESSING_DISPATCH_BATCH_SIZE=10
